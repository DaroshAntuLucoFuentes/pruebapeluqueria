# Google Calendar API Configuration
# Obtén estas credenciales desde: https://console.cloud.google.com/

# ID del cliente OAuth 2.0
GOOGLE_CLIENT_ID=

# Secret del cliente OAuth 2.0
GOOGLE_CLIENT_SECRET=

# URI de redirección configurada en Google Cloud Console
GOOGLE_REDIRECT_URI=

# Refresh token obtenido después de la autenticación inicial
# Este token permite renovar automáticamente el access token
GOOGLE_REFRESH_TOKEN=

# ID del calendario a usar (por defecto "primary" para el calendario principal)
GOOGLE_CALENDAR_ID=primary
